# ============ AI 服务 ============
# DeepSeek API Key（用于AI总结和追踪报告生成，必填）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ============ 认证 ============
# JWT 密钥（生产环境请使用强随机字符串）
JWT_SECRET=your-jwt-secret-change-in-production

# ============ 支付（可选，不配置则支付功能不可用） ============
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PRICE_ID_MONTHLY=price_your_monthly_price_id

# ============ 网络代理 ============
# 代理地址（用于访问 YouTube 等需要翻墙的平台，留空则不使用代理）
# 格式: http://IP:PORT 或 socks5://IP:PORT
PROXY_URL=

# ============ VIP 特权用户（可选） ============
# 配置后该邮箱注册/登录自动获得永久VIP，用于内部测试
# 不配置则不影响任何功能，所有用户均为普通用户
# VIP_EMAIL=your_email@example.com
# VIP_PASSWORD=your_secure_password

# ============ 其他 ============
# 前端 URL（用于 Stripe 支付回跳）
FRONTEND_URL=http://localhost:5173
